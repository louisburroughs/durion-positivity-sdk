    "@durion-sdk/catalog": "*",
    "@durion-sdk/inventory": "*",
    "@durion-sdk/workorder": "*",
    "@durion-sdk/order": "*",
    "@durion-sdk/accounting": "*",
    "@durion-sdk/vehicle-inventory": "*",
    "@durion-sdk/invoice": "*"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@types/node": "^22.0.0",
