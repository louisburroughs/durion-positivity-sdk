{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@durion-sdk/*": ["packages/sdk-*/src"]
    }
  },
  "include": ["src/**/*", "packages/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}