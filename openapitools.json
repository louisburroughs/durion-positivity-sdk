{
  "$schema": "node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.5.0",
    "generators": {
      "sdk-security": {
        "generatorName": "typescript-fetch",
        "output": "packages/sdk-security",
        "inputSpec": "../durion-positivity-backend/pos-security-service/openapi.yaml",
        "additionalProperties": {
          "npmName": "@durion-sdk/security",
          "npmVersion": "0.1.0-alpha",
          "supportsES6": true,
          "stringEnums": true,
          "withSeparateModelsAndApi": true,
          "modelPackage": "src/models",
          "apiPackage": "src/apis",
          "gitUserId": "positivity-durion",
          "gitRepoId": "durion-positivity-sdk"
        }
      },
      "sdk-order": {
        "generatorName": "typescript-fetch",
        "output": "packages/sdk-order",
